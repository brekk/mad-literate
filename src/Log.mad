import { env, tag, tagWithScope } from "PartyBus"



LIT = "mad-literate"
scoped = tagWithScope(LIT)

export TAGS = {
  base: tag(LIT),
  headmatter: scoped(["headmatter"]),
  body: scoped(["headmatter"]),
  cli: scoped(["cli"]),
}

export log = {
  base: env(TAGS.base),
  headmatter: env(TAGS.headmatter),
  body: env(TAGS.body),
  cli: env(TAGS.cli),
}
