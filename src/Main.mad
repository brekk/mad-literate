import { showVersion } from "@/MadlibJson/Version"
import {
  brace,
  concat,
  encomment,
  enquote,
  entype,
  hasBar,
  hasComma,
  hasDoubleColon,
  hasHeadMatter,
} from "@/String"



definition = [
  Flag("cwd", ["c"], ParseString, Unspecial),
  Flag("input", ["i"], ParseString, Unspecial),
  Flag("output", ["o"], ParseString, Unspecial),
  Flag("run", ["r"], ParseBoolean, Unspecial),
  Flag("help", ["h"], ParseBoolean, Exclusive),
]
alias MargsConfig = {
  cwd :: String,
  help :: Boolean,
  input :: String,
  output :: String,
  run :: Boolean,
}
// type MargsConfigParsed = MargsConfigParsed(MargsConfig)

// parser :: Json.Parser MargsConfigParsed
// parser = Json.map5((cwd, help, input, output, run) => 

// parseArgs :: Either (List ConcreteExpression) (Dictionary String ConcreteExpression)
parseArgs = where {
  Either.Left(raw) =>
    Either.Left(raw)

  Either.Right(dict) =>
    do {
      // Dict.get expects consistent values, so we're cheating that a bit
      getDef = (def, x) => pipe(
        Dict.get($, dict),
        map(stringValue),
        fromMaybe(def),
      )(x)
      mistake = "MARGS_NON_STRING"
      toBool = (x) => x == mistake ? false : true
      getBool = pipe(
        getDef(mistake),
        toBool,
      )
      getString = getDef(mistake)
      input = getString("input")
      output = getString("output")
      run = getBool("run")
      help = getBool("help")
      cwd = getDef(".", "cwd")
      out :: MargsConfig
      out = { input, output, run, help, cwd }
      return Either.Right(out)
    }
}



madlibJson = pipe(
  log.base("madlib.json"),
  File.read,
  log.base("read from"),
  // SpiritGum.VFile.forceVFileError,
  map(MadlibJson.parse),
)("./madlib.json")

// literati = (version, raw) => pipe(
//   String.lines,
//   Fn.ifElse(hasHeadMatter, processFileWithHeadmatter(version), processBody),
// )(raw)

margsParser = pipe(
  parser(definition),
  parseArgs,
)


relative = (cwd, i) => FilePath.joinPath([cwd, i])


// readAndWriteToFile :: String -> String -> String -> Wish String Boolean
// readAndWriteToFile = (version, input, output) => {
//   transform = pipe(
//     File.read,
//     map(literati(version)),
//     chain(File.write(output)),
//     map(Fn.always(true)),
//     Wish.mapRej(Fn.always("Unable to write to file: " ++ output)),
//   )
//   return transform(input)
// }

ender = Wish.fulfill(
  (e) => {
    IO.pTrace("bad", e)
    return {}
  },
  (x) => {
    IO.pTrace("Created new file from source:", show(x))
    return {}
  },
)

RULES = [
  SpiritGum
    .Rule
    .bodyRule(
      false,
      "smoke-test",
      [],
      [SpiritGum.Transformer.ofBodyState((meta, _) => ({ ...meta, hasHeadmarker: true }))],
    ),
]
alias LiterateState = { hasHeadmarker :: Boolean, hasMadmarker :: Boolean }

STATE :: LiterateState
STATE = { hasHeadmarker: false, hasMadmarker: false }

useSpiritGum :: String -> String -> String -> Wish String String
useSpiritGum = (version, input, output) => pipe(
  SpiritGum.VFile.fromPath($, RULES, STATE),
  Wish.mapRej(Fn.always("Unable to process virtual file")),
  map(
    SpiritGum
      .Template
      .renderWithConverter(map(SpiritGum.Line.render), (_, lines, _) => String.unlines(lines)),
  ),
  chain(
    pipe(
      File.write(output),
      // SpiritGum.VFile.forceVFileError,
      map(Fn.always("Written!")),
      Wish.mapRej(Fn.always("Unable to write!")),
    ),
  ),
)(input)

convert :: String -> List String -> Either String (Wish String String)
convert = (version, raw) => pipe(
  chop(1),
  String.unwords,
  // string to Either
  margsParser,
  map(
    (args) => {
      locate = relative(args.cwd)
      input = locate(args.input)
      output = locate(args.output)
      // return readAndWriteToFile(version, input, output)
      return useSpiritGum(version, input, output)
    },
  ),
)(raw)

consumer = (json, rawargs) => pipe(
  convert(showVersion(json.version)),
  map(SpiritGum.VFile.forceVFileError),
  Either.fromRight(Wish.bad(SpiritGum.InvalidSource)),
  ender,
)(rawargs)


main = (rawargs) => {
  pipe(
    Wish.mapRej(Fn.always("BARF")),
    chain(map(consumer($, rawargs))),
    ender,
  )(madlibJson)
}
