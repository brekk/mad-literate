import type { Wish } from "Wish"

import type { VFileLine } from "spirit-gum/Line"

import Fn from "Function"
import IO from "IO"
import { fromMaybe } from "Maybe"
import String from "String"

import Line from "spirit-gum/Line"

import { COMMENT, INDENT, MAIN_START } from "@/Constants"
import _String from "@/String"



K = Fn.always
export _printFlag = (k, v) => Fn.complement(String.isEmpty)(v) ? k ++ " " ++ v : ""
export printFlags = ({ input, output, multiLine }) => "madlit "
    ++ _printFlag("-i", input)
    ++ " "
    ++ _printFlag("-o", output)
    ++ " "
    ++ _printFlag("", multiLine ? "--multi-line" : "")
/*
map(
    Fn.unless(
      Fn.either(String.isEmpty, String.startsWith(INDENT)),
      (y) => codeOnly ? "" : mappend(COMMENT ++ " ", y),
    ),
  ),
*/

killMadTicks = pipe(
  _String.tickMedicine,
  Fn.when(String.startsWith("madlib"), K("")),
)
slam = (codeOnly, y) => codeOnly ? "" : mappend(COMMENT ++ " ", y)
exclusiveMatch = (sclusy, match, y) => !sclusy && !String.startsWith(match, y)
renderSoloLine :: Integer -> (Integer -> Boolean) -> Boolean -> Boolean -> VFileLine -> String
export renderSoloLine = (madmarker, check, exclusive, codeOnly, x) => pipe(
  where {
    Line.ValidLine(i, _x) =>
      if (i == madmarker) {
        MAIN_START
      } else if (!String.isEmpty(_x)) {
        if (exclusive && !check(i)) do {
          return slam(codeOnly, _x)
        } else if (exclusiveMatch(exclusive, INDENT, _x)) {
          slam(codeOnly, _x)
        } else if (check(i)) {
          killMadTicks(_x)
        } else {
          _x
        }
      } else {
        _x
      }

    Line.VirtualLine(_x) =>
      _x

    _ =>
      ""
  },
)(x)
